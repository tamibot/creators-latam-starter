# === Credenciales del proyecto ===
# Copiá este archivo como `.env` y rellenalo.
# NUNCA subas `.env` al repo. Ya está en .gitignore.

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# --- GitHub ---
GITHUB_TOKEN=ghp_...

# --- CRM (Kommo, HubSpot, etc.) ---
CRM_API_KEY=
CRM_SUBDOMAIN=

# --- WhatsApp / Mensajería ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# --- Workflow (n8n, Zapier, Make) ---
N8N_WEBHOOK_URL=
N8N_API_KEY=

# --- Cloud / Deploy ---
RAILWAY_TOKEN=
VERCEL_TOKEN=

# --- Otros ---
# Agregá acá las credenciales específicas del cliente.
