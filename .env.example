# === Credenciales del proyecto ===
# Copiá este archivo como `.env` y rellenalo.
# NUNCA subas `.env` al repo. Ya está en .gitignore.

# ------------------------------------------------------------------
# ℹ️  CLAUDE CODE: si usás Claude Code como IDE, NO necesitás setear
#    ANTHROPIC_API_KEY acá — Claude Code usa su propia sesión (login
#    desde el CLI). Sólo seteá ANTHROPIC_API_KEY si vas a hacer
#    llamadas a la API de Anthropic desde tu código Python/Node.
# ------------------------------------------------------------------

# --- LLM providers (para llamadas directas desde código, no Claude Code) ---
ANTHROPIC_API_KEY=            # (opcional si usás Claude Code)
OPENAI_API_KEY=

# Gemini API (usado por el skill `video-a-texto` para analizar video/audio)
# Conseguilo gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- GitHub ---
# No lo necesitás si ya hiciste `gh auth login` — gh maneja su propio token.
GITHUB_TOKEN=

# --- CRM (Kommo, HubSpot, etc.) ---
CRM_API_KEY=
CRM_SUBDOMAIN=

# --- WhatsApp / Mensajería ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# --- Workflow (n8n, Zapier, Make) ---
N8N_WEBHOOK_URL=
N8N_API_KEY=

# --- Cloud / Deploy ---
RAILWAY_TOKEN=
VERCEL_TOKEN=

# --- Otros ---
# Agregá acá las credenciales específicas del cliente (Fase 2 del Plan Maestro).
